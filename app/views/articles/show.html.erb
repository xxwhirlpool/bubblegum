<div class="main h-entry">

<header>
	<h1 class="p-name"><%= @article.title %></h1>
</header>

<%= render "navbar" %>

<% if @article.icon.attached? %>
    <%= image_tag url_for(@article.icon) %>
<% end %>

<div class="article_info">
	<div class="article_date_text">
		<time class="article_time dt-published" <%= tag.attributes datetime: @article.created_at.strftime('%Y-%m-%d') %> ><%= @article.created_at.strftime('%Y %b %d') %></time>
	</div>
	<span class="tag_link">
		<span aria-hidden="true">|</span>
		<%= link_to @article.tag.name, @article.tag, class: "p-category" %>
		<span aria-hidden="true">|</span>
		<span style="color:var(--main-color);">
			<%= @article.body.scan(/[\p{Alpha}\-']+/).size %> words
		</span>
		<span aria-hidden="true">|</span>
	</span>
	<a href="mailto:&#x77;&#x69;&#x74;&#x6E;&#x65;&#x73;&#x73;&#x6C;&#x61;&#x63;&#x68;&#x65;&#x73;&#x69;&#x73;&#x40;&#x64;&#x69;&#x73;&#x72;&#x6F;&#x6F;&#x74;&#x2E;&#x6F;&#x72;&#x67;?subject=re: <%= @article.title %>">reply via email</a>
</div>

<div class="pbody">
	<article>
		<%== markdown(@article.body) %>
	</article>
</div>

<% if user_signed_in? %>
<p class="pbody">
<%= link_to "edit", edit_article_path(@article) %> |
<%= link_to "destroy", article_path(@article), data: {
                    turbo_method: :delete,
                    turbo_confirm: "Are you sure?"
                  } %>
</p>
<% else %>
<% end %>

<hr>

<div class="bubbles-vote"></div>
<script src="https://bubbles.town/vote.js" defer></script>

<div id="webmentions_bbgm">
	<h3 id="webmentions">webmentions</h3>

	<ul id="wbm-mentions-list" style="margin-block-end:1.5rem;"></ul>

	<ul id="wbm-likes-rbs-count"></ul>

	<script>
		// ty to my dear friend jordan for reworking most of the below code!!
		const postUrl = window.location.href;

		async function wbmJson() {
			try {
				const mentionsRes = await fetch(`https://webmention.io/api/mentions.jf2?target=${postUrl}`);
				const mentionsData = await mentionsRes.json();

				// fallback to empty array if no mentions
				const mentions = mentionsData.children || [];

				// Fetch like & repost counts (one request instead of two)
		        const countRes = await fetch(`https://webmention.io/api/count.json?target=${postUrl}`);
		        const counts = await countRes.json();

		        // convert undefined/null to 0
		        const likeCount = counts.type.like || 0;
		        const repostCount = counts.type.repost || 0;

				// Build the HTML for replies & mentions
				const mentionsHtml = mentions
					.filter((wm) => ["in-reply-to", "mention-of"].includes(wm["wm-property"]))
					.map((m) => {
						// Safe author name: use name, or URL, or "Anonymous" if both missing
						const authorName = m.author?.name || m.author?.url || "[unknown]";

						// Safe content: show text or fallback message
						const content = m.content?.text || "(no text)";

						return `
							<li>
								<a href="${m.url}" target="_blank" rel="noopener">${authorName}</a> said: ${content}
							</li>
						`;
					})
					// converts array into one string (AKA removes the commas)
					.join("");

					document.getElementById("wbm-mentions-list").innerHTML = mentionsHtml;

				// Only show likes/reposts if there is at least one
				if (likeCount > 0 || repostCount > 0) {
					document.getElementById("wbm-likes-rbs-count").innerHTML =
						`<li>
							<span style="color: var(--main-color);">${likeCount}</span> likes
						</li>
						<li>
							<span style="color: var(--main-color);">${repostCount}</span> reposts
						</li>`
					};
			} catch (err) {
				console.error("failed to load webmentions:", err)
			}
		};

		// run function on page load
		wbmJson();
	</script>

	<%= render "articles/wbmnform" %>
	
</div>

<%= render "articles/hcard" %>

</div>
